# ─── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql://tripguard:tripguard@localhost:5433/tripguard

# ─── Neo4j AuraDB ──────────────────────────────────────────
# Get from: https://neo4j.com/cloud/aura-free/
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-aura-password

# ─── OpenAI ────────────────────────────────────
# Used by AI agents (recommendation, trust scoring, etc.)
OPENAI_API_KEY=sk-ant-...

# ─── TAT (Tourism Authority of Thailand) API ───────────────
# Register at: https://tatapi.tourismthailand.org/
TAT_API_KEY=your-tat-api-key
TAT_API_BASE=https://tatapi.tourismthailand.org/tatapi/v5

# ─── JWT Auth ──────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string

# ─── Frontend ──────────────────────────────────────────────
# For Vite - prefix with VITE_
VITE_API_BASE_URL=http://localhost:3001
VITE_MAPBOX_TOKEN=pk.eyJ1...   # OR use react-leaflet (free, no token)
